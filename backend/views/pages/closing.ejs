<%- include('../partials/head') %>
<div class="layout">
  <%- include('../partials/sidebar') %>
  <div class="main">
    <%- include('../partials/topbar') %>
    <div class="content">
      <div class="page-header">
        <div>
          <div class="page-title">Daily Closing</div>
          <div class="page-sub"><%= new Date().toLocaleDateString('en-IN', {weekday:'long',year:'numeric',month:'long',day:'numeric'}) %></div>
        </div>
        <% if (existing) { %>
          <span class="badge badge--green" style="font-size:13px;padding:8px 16px">✅ Closed for Today</span>
        <% } %>
      </div>

      <div class="grid-2">
        <!-- Sales summary -->
        <div>
          <div class="card mb-16">
            <div class="card-title">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
              Today's Sales (<%= billCount %> bills)
            </div>
            <div style="display:flex;flex-direction:column;gap:8px">
              <% [['Cash','cash',cash],['UPI','upi',upi],['Card','card',card],['Credit','credit',credit]].forEach(([label,,val]) => { %>
              <div style="display:flex;justify-content:space-between;align-items:center;padding:12px;background:var(--bg3);border-radius:8px">
                <span class="text-muted"><%= label %></span>
                <span class="fw-bold" style="font-family:var(--font-head);font-size:16px">₹<%= parseFloat(val).toFixed(2) %></span>
              </div>
              <% }) %>
              <div style="display:flex;justify-content:space-between;align-items:center;padding:14px;background:rgba(249,115,22,.08);border:1px solid rgba(249,115,22,.2);border-radius:8px;margin-top:4px">
                <span class="fw-bold">Total Sales</span>
                <span style="font-family:var(--font-head);font-size:20px;font-weight:800;color:var(--accent)">₹<%= parseFloat(totalSales).toFixed(2) %></span>
              </div>
            </div>
          </div>
          <div class="card">
            <div class="card-title">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              Today's Expenses
            </div>
            <div style="padding:16px;background:var(--bg3);border-radius:var(--radius);text-align:center">
              <div class="text-dim text-xs" style="margin-bottom:6px">TOTAL EXPENSES</div>
              <div style="font-family:var(--font-head);font-size:26px;font-weight:800;color:var(--red)">₹<%= parseFloat(totalExp).toFixed(2) %></div>
            </div>
          </div>
        </div>

        <!-- Closing form -->
        <div class="card">
          <div class="card-title">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            Close Shop Summary
          </div>

          <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:18px">
            <div style="display:flex;justify-content:space-between;padding:10px;background:var(--bg3);border-radius:8px">
              <span class="text-muted">Total Sales</span><span class="fw-bold">₹<%= parseFloat(totalSales).toFixed(2) %></span>
            </div>
            <div style="display:flex;justify-content:space-between;padding:10px;background:var(--bg3);border-radius:8px">
              <span class="text-muted">Total Expenses</span><span class="fw-bold text-red">₹<%= parseFloat(totalExp).toFixed(2) %></span>
            </div>
            <div style="display:flex;justify-content:space-between;padding:14px;background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:8px">
              <span class="fw-bold">Net Profit</span>
              <span style="font-family:var(--font-head);font-size:20px;font-weight:800;color:var(--green)">₹<%= parseFloat(netProfit).toFixed(2) %></span>
            </div>
            <div style="display:flex;justify-content:space-between;padding:10px;background:var(--bg3);border-radius:8px">
              <span class="text-muted">Expected Cash in Hand</span><span class="fw-bold">₹<%= parseFloat(cash).toFixed(2) %></span>
            </div>
          </div>

          <% if (!existing) { %>
          <form action="/closing" method="POST">
            <input type="hidden" name="cash"        value="<%= cash %>" />
            <input type="hidden" name="upi"         value="<%= upi %>" />
            <input type="hidden" name="card"        value="<%= card %>" />
            <input type="hidden" name="credit"      value="<%= credit %>" />
            <input type="hidden" name="total_sales" value="<%= totalSales %>" />
            <input type="hidden" name="total_exp"   value="<%= totalExp %>" />
            <input type="hidden" name="net_profit"  value="<%= netProfit %>" />
            <div class="form-group">
              <label class="form-label">Actual Cash in Hand (₹)</label>
              <input class="form-input" name="actual_cash" type="number" min="0" step="0.01" value="<%= parseFloat(cash).toFixed(2) %>" required />
            </div>
            <div class="form-group">
              <label class="form-label">Notes</label>
              <textarea class="form-textarea" name="notes" rows="2" placeholder="Any notes for today..."></textarea>
            </div>
            <button type="submit" class="btn-primary-full" style="font-size:15px">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
              Close Shop for Today
            </button>
          </form>
          <% } else { %>
          <div style="text-align:center;padding:20px">
            <div style="font-size:40px;margin-bottom:12px">🌙</div>
            <div class="fw-bold" style="font-size:16px;margin-bottom:8px">Shop closed for today!</div>
            <% if (existing.cash_mismatch != 0) { %>
              <div style="padding:12px;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);border-radius:8px;margin-top:12px">
                <div style="font-weight:700;color:var(--red)">⚠ Cash Mismatch</div>
                <div style="font-size:13px;color:var(--red);margin-top:4px">
                  ₹<%= Math.abs(parseFloat(existing.cash_mismatch)).toFixed(2) %>
                  <%= parseFloat(existing.cash_mismatch) > 0 ? 'extra' : 'short' %>
                </div>
              </div>
            <% } else { %>
              <div class="badge badge--green" style="font-size:13px">✅ No cash mismatch</div>
            <% } %>
            <% if (existing.notes) { %>
              <div style="margin-top:12px;padding:10px;background:var(--bg3);border-radius:8px;font-size:12px;color:var(--text3)"><%= existing.notes %></div>
            <% } %>
          </div>
          <% } %>
        </div>
      </div>

    </div>
  </div>
</div>
<%- include('../partials/footer') %>
