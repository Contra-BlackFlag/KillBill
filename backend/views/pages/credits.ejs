<%- include('../partials/head') %>
<div class="layout">
  <%- include('../partials/sidebar') %>
  <div class="main">
    <%- include('../partials/topbar') %>
    <div class="content">
      <div class="page-header">
        <div>
          <div class="page-title">Udhar / Credit</div>
          <div class="page-sub">Total pending: <span style="color:var(--red)">₹<%= totalPending.toLocaleString('en-IN',{maximumFractionDigits:2}) %></span></div>
        </div>
        <button class="btn btn-accent" onclick="openModal('add-credit-modal')">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Credit
        </button>
      </div>

      <!-- Filter tabs -->
      <div class="section-tabs">
        <% ['all','pending','partial','paid'].forEach(s => { %>
          <a href="/credits?status=<%= s %>" class="section-tab <%= statusFilter === s ? 'active' : '' %>">
            <%= s.charAt(0).toUpperCase() + s.slice(1) %>
          </a>
        <% }) %>
      </div>

      <div class="card">
        <% if (!credits.length) { %>
          <div class="empty-state">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
            <p>No credit records</p>
          </div>
        <% } else { %>
        <div class="table-wrap">
          <table class="data-table">
            <thead><tr><th>Customer</th><th>Amount</th><th>Paid</th><th>Remaining</th><th>Due Date</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
              <% credits.forEach(c => {
                const rem = parseFloat(c.amount) - parseFloat(c.paid_amount || 0);
                const overdue = c.due_date && new Date(c.due_date) < new Date() && c.status !== 'paid';
              %>
              <tr>
                <td>
                  <div class="fw-bold"><%= c.customers?.name || 'Unknown' %></div>
                  <div class="text-dim text-xs"><%= c.customers?.phone || '' %></div>
                </td>
                <td>₹<%= parseFloat(c.amount).toFixed(2) %></td>
                <td style="color:var(--green)">₹<%= parseFloat(c.paid_amount||0).toFixed(2) %></td>
                <td class="fw-bold <%= rem > 0 ? 'text-red' : '' %>">₹<%= rem.toFixed(2) %></td>
                <td>
                  <% if (c.due_date) { %>
                    <span class="<%= overdue ? 'badge badge--red' : 'text-muted' %>">
                      <%= overdue ? '⚠ ' : '' %><%= new Date(c.due_date).toLocaleDateString('en-IN') %>
                    </span>
                  <% } else { %>—<% } %>
                </td>
                <td><span class="badge badge--<%= c.status==='paid'?'green':c.status==='partial'?'yellow':'red' %>"><%= c.status %></span></td>
                <td>
                  <div style="display:flex;gap:4px">
                    <% if (c.status !== 'paid') { %>
                      <button class="btn btn-sm btn-green" onclick="openPayModal('<%= c.id %>',<%= rem %>)">Collect</button>
                    <% } %>
                    <form action="/credits/<%= c.id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete this credit?')">
                      <button type="submit" class="btn btn-sm btn-danger">🗑</button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Add Credit Modal -->
<div class="modal-overlay" id="add-credit-modal" style="display:none" onclick="if(event.target===this)closeModal('add-credit-modal')">
  <div class="modal" style="max-width:460px">
    <div class="modal-header"><span class="modal-title">Add Credit / Udhar</span><button type="button" class="btn btn-sm btn-ghost" onclick="closeModal('add-credit-modal')">✕</button></div>
    <form action="/credits" method="POST">
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">Customer *</label>
          <select class="form-select" name="customer_id" required>
            <option value="">Select customer</option>
            <% customers.forEach(c => { %>
              <option value="<%= c.id %>"><%= c.name %><%= c.phone ? ` (${c.phone})` : '' %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-row-2">
          <div class="form-group"><label class="form-label">Amount (₹) *</label><input class="form-input" name="amount" type="number" min="0.01" step="0.01" required placeholder="1500" /></div>
          <div class="form-group"><label class="form-label">Due Date</label>
            <input class="form-input" name="due_date" type="date"
              value="<%= new Date(Date.now()+7*864e5).toISOString().split('T')[0] %>" />
          </div>
        </div>
        <div class="form-group"><label class="form-label">Notes</label><input class="form-input" name="notes" placeholder="Reason for credit..." /></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeModal('add-credit-modal')">Cancel</button>
        <button type="submit" class="btn btn-accent">Add Credit</button>
      </div>
    </form>
  </div>
</div>

<!-- Payment Modal -->
<div class="modal-overlay" id="pay-modal" style="display:none" onclick="if(event.target===this)closeModal('pay-modal')">
  <div class="modal" style="max-width:400px">
    <div class="modal-header"><span class="modal-title">Collect Payment</span><button type="button" class="btn btn-sm btn-ghost" onclick="closeModal('pay-modal')">✕</button></div>
    <form id="pay-form" method="POST">
      <div class="modal-body">
        <div id="pay-due-info" style="padding:14px;background:var(--bg3);border-radius:var(--radius);margin-bottom:14px;font-size:13px"></div>
        <div class="form-row-2">
          <div class="form-group"><label class="form-label">Amount *</label><input class="form-input" name="amount" id="pay-amount" type="number" min="0.01" step="0.01" required /></div>
          <div class="form-group"><label class="form-label">Mode</label>
            <select class="form-select" name="payment_mode">
              <option value="cash">Cash</option><option value="upi">UPI</option><option value="card">Card</option>
            </select>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeModal('pay-modal')">Cancel</button>
        <button type="submit" class="btn btn-green">✅ Collect</button>
      </div>
    </form>
  </div>
</div>

<script>
function openModal(id)  { document.getElementById(id).style.display = 'flex'; }
function closeModal(id) { document.getElementById(id).style.display = 'none'; }
function openPayModal(creditId, remaining) {
  document.getElementById('pay-form').action = `/credits/${creditId}/pay`;
  document.getElementById('pay-amount').value = remaining.toFixed(2);
  document.getElementById('pay-amount').max = remaining;
  document.getElementById('pay-due-info').innerHTML =
    `<div style="display:flex;justify-content:space-between"><span style="color:var(--text2)">Remaining Due</span><strong style="color:var(--red)">₹${remaining.toFixed(2)}</strong></div>`;
  openModal('pay-modal');
}
</script>
<%- include('../partials/footer') %>
