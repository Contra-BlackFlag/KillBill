<%- include('../partials/head') %>
<div class="layout">
  <%- include('../partials/sidebar') %>
  <div class="main">
    <%- include('../partials/topbar') %>
    <div class="content">
      <div class="page-header">
        <div>
          <a href="/customers" style="font-size:12px;color:var(--text3)">← All Customers</a>
          <div class="page-title"><%= customer.name %></div>
          <div class="page-sub"><%= customer.phone || '' %> <% if(customer.address){ %> · <%= customer.address %><% } %></div>
        </div>
        <% if (parseFloat(customer.total_credit) > 0) { %>
          <div style="text-align:right">
            <div class="text-dim text-xs">TOTAL CREDIT DUE</div>
            <div style="font-family:var(--font-head);font-size:22px;font-weight:800;color:var(--red)">₹<%= parseFloat(customer.total_credit).toFixed(2) %></div>
          </div>
        <% } %>
      </div>

      <div class="card">
        <div class="card-title">Purchase History</div>
        <% if (!bills.length) { %>
          <div class="empty-state"><p>No purchases yet</p></div>
        <% } else { %>
          <div class="table-wrap">
            <table class="data-table">
              <thead><tr><th>Bill #</th><th>Date</th><th>Total</th><th>Mode</th><th>Status</th><th></th></tr></thead>
              <tbody>
                <% bills.forEach(b => { %>
                <tr>
                  <td class="fw-bold"><%= b.bill_number %></td>
                  <td class="text-dim"><%= new Date(b.created_at).toLocaleDateString('en-IN') %></td>
                  <td class="fw-bold" style="color:var(--accent)">₹<%= parseFloat(b.total).toFixed(2) %></td>
                  <td><span class="badge badge--gray"><%= b.payment_mode.toUpperCase() %></span></td>
                  <td><span class="badge badge--<%= b.payment_status==='paid'?'green':'red' %>"><%= b.payment_status %></span></td>
                  <td><a href="/billing/<%= b.id %>" class="btn btn-sm btn-ghost">View</a></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
