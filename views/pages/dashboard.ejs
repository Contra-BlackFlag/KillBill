<%- include('../partials/head') %>
<div class="layout">
  <%- include('../partials/sidebar') %>
  <div class="main">
    <%- include('../partials/topbar') %>
    <div class="content">

      <!-- KPI cards -->
      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-icon stat-icon--orange">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
          </div>
          <div class="stat-label">Today's Sales</div>
          <div class="stat-value stat-value--orange">₹<%= todaySales.toLocaleString('en-IN', {minimumFractionDigits:0, maximumFractionDigits:2}) %></div>
          <div class="stat-sub"><%= todayBillCount %> bills today</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon stat-icon--green">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <div class="stat-label">Today's Profit</div>
          <div class="stat-value stat-value--green">₹<%= (todaySales - todayExpSum).toLocaleString('en-IN', {minimumFractionDigits:0, maximumFractionDigits:2}) %></div>
          <div class="stat-sub">Exp: ₹<%= todayExpSum.toLocaleString('en-IN', {maximumFractionDigits:2}) %></div>
        </div>
        <div class="stat-card">
          <div class="stat-icon stat-icon--blue">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div class="stat-label">Month Sales</div>
          <div class="stat-value stat-value--blue">₹<%= monthSales.toLocaleString('en-IN', {minimumFractionDigits:0, maximumFractionDigits:2}) %></div>
          <div class="stat-sub"><%= monthBillCount %> bills this month</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon stat-icon--red">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          </div>
          <div class="stat-label">Pending Credit</div>
          <div class="stat-value stat-value--red">₹<%= pendingAmt.toLocaleString('en-IN', {minimumFractionDigits:0, maximumFractionDigits:2}) %></div>
          <div class="stat-sub"><%= pendingCredits.length %> accounts</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon stat-icon--yellow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <div class="stat-label">Low Stock Items</div>
          <div class="stat-value stat-value--yellow"><%= lowStock.length %></div>
          <div class="stat-sub">need restocking</div>
        </div>
      </div>

      <!-- Charts row -->
      <div class="grid-2 mb-16">
        <div class="card">
          <div class="card-title">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            Sales — Last 7 Days
          </div>
          <div class="chart-wrap">
            <canvas id="chart-sales"></canvas>
          </div>
        </div>
        <div class="card">
          <div class="card-title">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.21 15.89A10 10 0 1 1 8 2.83"/><path d="M22 12A10 10 0 0 0 12 2v10z"/></svg>
            Payment Modes Today
          </div>
          <div class="chart-wrap">
            <canvas id="chart-modes"></canvas>
          </div>
        </div>
      </div>

      <!-- Bottom row -->
      <div class="grid-2">
        <!-- Low stock -->
        <div class="card">
          <div class="card-title">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Low Stock Alert
          </div>
          <% if (lowStock.length === 0) { %>
            <div class="empty-state">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>
              <p>All products well stocked</p>
            </div>
          <% } else { %>
            <div class="table-wrap">
              <table class="data-table">
                <thead><tr><th>Product</th><th>Stock</th><th>Alert</th><th></th></tr></thead>
                <tbody>
                  <% lowStock.slice(0,5).forEach(p => { %>
                  <tr>
                    <td><strong><%= p.name %></strong></td>
                    <td><span class="badge badge--red"><%= p.quantity %> <%= p.unit || 'pcs' %></span></td>
                    <td class="text-dim"><%= p.low_stock_alert %></td>
                    <td><a href="/inventory" class="btn btn-sm btn-accent">Restock</a></td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>

        <!-- Pending credits -->
        <div class="card">
          <div class="card-title">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Pending Credits
          </div>
          <% if (pendingCredits.length === 0) { %>
            <div class="empty-state">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>
              <p>No pending payments</p>
            </div>
          <% } else { %>
            <div class="table-wrap">
              <table class="data-table">
                <thead><tr><th>Customer</th><th>Due</th><th>Status</th></tr></thead>
                <tbody>
                  <% pendingCredits.forEach(c => { %>
                  <tr>
                    <td>
                      <strong><%= c.customers?.name || 'Unknown' %></strong>
                      <div class="text-dim text-xs"><%= c.customers?.phone || '' %></div>
                    </td>
                    <td class="text-red fw-bold">₹<%= (parseFloat(c.amount) - parseFloat(c.paid_amount || 0)).toLocaleString('en-IN', {maximumFractionDigits:2}) %></td>
                    <td><span class="badge badge--<%= c.status === 'partial' ? 'yellow' : 'red' %>"><%= c.status %></span></td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <a href="/credits" class="btn btn-ghost btn-sm" style="margin-top:12px">View all →</a>
          <% } %>
        </div>
      </div>

    </div><!-- /content -->
  </div><!-- /main -->
</div><!-- /layout -->

<script>
document.addEventListener('DOMContentLoaded', () => {
  const labels = <%- JSON.stringify(last7Labels) %>;
  const data   = <%- JSON.stringify(last7Data) %>;
  const modesL = <%= modesLabels %>;
  const modesD = <%= modesData %>;

  new Chart(document.getElementById('chart-sales'), {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        data,
        backgroundColor: 'rgba(249,115,22,.65)',
        borderColor: '#f97316',
        borderWidth: 1,
        borderRadius: 6
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { color: 'rgba(255,255,255,.04)' }, ticks: { color: '#64748b', font: { size: 11 } } },
        y: { grid: { color: 'rgba(255,255,255,.04)' }, ticks: { color: '#64748b', font: { size: 11 }, callback: v => '₹' + v.toLocaleString('en-IN') } }
      }
    }
  });

  new Chart(document.getElementById('chart-modes'), {
    type: 'doughnut',
    data: {
      labels: modesL.length ? modesL : ['No Data'],
      datasets: [{
        data: modesD.some(v => v > 0) ? modesD : [1],
        backgroundColor: modesD.some(v => v > 0)
          ? ['#f97316','#22c55e','#3b82f6','#a855f7']
          : ['#1e2a3a'],
        borderWidth: 0
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom', labels: { color: '#94a3b8', font: { size: 11 }, padding: 12 } } },
      cutout: '65%'
    }
  });
});
</script>
<%- include('../partials/footer') %>
