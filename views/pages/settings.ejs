<%- include('../partials/head') %>
<div class="layout">
  <%- include('../partials/sidebar') %>
  <div class="main">
    <%- include('../partials/topbar') %>
    <div class="content">
      <div class="page-title" style="margin-bottom:20px">Settings</div>
      <div class="grid-2">
        <div class="card">
          <div class="card-title">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
            Shop Information
          </div>
          <form action="/settings" method="POST">
            <div class="form-row-2">
              <div class="form-group"><label class="form-label">Shop Name</label><input class="form-input" name="shop_name" value="<%= profile.shop_name || '' %>" /></div>
              <div class="form-group"><label class="form-label">Owner Name</label><input class="form-input" name="owner_name" value="<%= profile.owner_name || '' %>" /></div>
            </div>
            <div class="form-group"><label class="form-label">Phone</label><input class="form-input" name="phone" value="<%= profile.phone || '' %>" /></div>
            <div class="form-group"><label class="form-label">Address</label><textarea class="form-textarea" name="address" rows="2"><%= profile.address || '' %></textarea></div>
            <div class="form-group"><label class="form-label">GST Number</label><input class="form-input" name="gst_number" value="<%= profile.gst_number || '' %>" placeholder="22AAAAA0000A1Z5" /></div>
            <button type="submit" class="btn btn-accent">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
              Save Settings
            </button>
          </form>
        </div>
        <div>
          <div class="card mb-16">
            <div class="card-title">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              Account
            </div>
            <div style="padding:14px;background:var(--bg3);border-radius:var(--radius);margin-bottom:14px">
              <div class="text-dim text-xs">EMAIL</div>
              <div class="fw-bold" style="margin-top:3px"><%= user.email %></div>
            </div>
            <form action="/auth/logout" method="POST">
              <button type="submit" class="btn btn-danger" style="width:100%;justify-content:center">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Sign Out
              </button>
            </form>
          </div>
          <div class="card">
            <div class="card-title">Quick Links</div>
            <div style="display:flex;flex-direction:column;gap:8px">
              <a href="/billing" class="btn btn-ghost" style="justify-content:flex-start">🧾 New Bill</a>
              <a href="/inventory" class="btn btn-ghost" style="justify-content:flex-start">📦 Inventory</a>
              <a href="/closing" class="btn btn-ghost" style="justify-content:flex-start">🌙 Daily Closing</a>
              <a href="/reports" class="btn btn-ghost" style="justify-content:flex-start">📊 Reports</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
